# ==================================================
# AccessDAO Protocol - Variáveis de Ambiente
# ==================================================
# INSTRUÇÕES:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores abaixo
# 3. NUNCA suba o arquivo .env para o GitHub!
# ==================================================

# Chave privada da carteira que vai fazer o deploy
# Obtenha no MetaMask: 3 pontos > Detalhes da conta > Mostrar chave privada
# ATENÇÃO: Use uma carteira SEM dinheiro real, apenas para testes!
PRIVATE_KEY=sua_chave_privada_aqui

# URL RPC da Sepolia Testnet
# Opções gratuitas:
# - Alchemy: https://dashboard.alchemy.com (recomendado)
# - Infura: https://infura.io
# - Público: https://rpc.sepolia.org
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/SUA_CHAVE_ALCHEMY

# API Key do Etherscan (para verificar contratos)
# Obtenha gratuitamente em: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=sua_chave_etherscan_aqui

# (Opcional) Para relatório de gas em USD
COINMARKETCAP_API_KEY=

# (Opcional) Ativa o relatório de gas nos testes
REPORT_GAS=true
